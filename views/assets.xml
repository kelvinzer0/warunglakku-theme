<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Asset bundle declarations for theme_warunglakku.
        Touch this comment timestamp on every deploy to force Odoo
        to regenerate the asset bundle with a NEW url hash, which
        bypasses CDN/Cloudflare cache (otherwise stale CSS gets
        served for users without cache-buster query param).

        Last touched: v3.10.53 (2026-07-15 05:45 UTC)
    -->

    <record id="asset_frontend_custom" model="ir.asset">
        <field name="name">Warung Lakku Custom Styles</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="directive">append</field>
        <field name="path">theme_warunglakku/static/src/scss/custom.scss</field>
    </record>

    <!--
        Register theme.js in the frontend bundle. The widget uses
        publicWidget.registry which is provided by web.public.widget
        (loaded in web.assets_frontend, NOT in the lazy bundle).

        Without this, theme.js was never actually loaded on /shop,
        so _initScrollEffects, _initWhatsAppButton, and
        _initOperatingHoursLiveStatus all silently did nothing.

        Fixed in v17.0.3.10.2.
    -->
    <record id="asset_frontend_custom_js" model="ir.asset">
        <field name="name">Warung Lakku Custom JS</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="directive">append</field>
        <field name="path">theme_warunglakku/static/src/js/theme.js</field>
    </record>

    <!--
        AJAX Add-to-Cart on product detail page.
        Intercepts #add_to_cart click on /shop/<slug>, POSTs to
        /shop/cart/update_json, updates cart counter + shows toast.
        Customer stays on product page (no redirect to /shop/cart).

        Loaded AFTER theme.js so bootstrap.Toast is already available.
        Fixed in v17.0.3.10.48.
    -->
    <record id="asset_frontend_ajax_add_to_cart_js" model="ir.asset">
        <field name="name">Warung Lakku AJAX Add to Cart JS</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="directive">append</field>
        <field name="path">theme_warunglakku/static/src/js/wl_ajax_cart.js</field>
    </record>

</odoo>
