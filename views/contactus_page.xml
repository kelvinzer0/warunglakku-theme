<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Warung Lakku - Contact Us Page
        ==============================
        Documents the expected content of /contactus page.
        Actual update done via RPC (company info + page arch).

        Company: Warung Lakku
        Address: Dusun Ngrekesan, Desa Ngadri, Kec. Binangun,
                 Kab. Blitar, Jawa Timur 66193, Indonesia
        WhatsApp: +62 857-3355-6953
        Email: hello@warunglakku.com
        Hours: Senin – Minggu, 10:00 – 22:00 WIB
    -->
    <data noupdate="1">
        <record id="website_contactus_page_info" model="ir.ui.view">
            <field name="name">Warung Lakku: Contact Us Info</field>
            <field name="key">theme_warunglakku.contactus_info</field>
            <field name="type">qweb</field>
            <field name="inherit_id" ref="website.contactus"/>
            <field name="active" eval="False"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//ul[contains(@class,'list-unstyled')]" position="replace">
                        <ul class="list-unstyled mb-0 ps-2">
                            <li><strong>Warung Lakku</strong></li>
                            <li><i class="fa fa-map-marker fa-fw me-2"/>
                                <span>Dusun Ngrekesan, Desa Ngadri,<br/>
                                Kec. Binangun, Kab. Blitar,<br/>
                                Jawa Timur 66193, Indonesia</span>
                            </li>
                            <li><i class="fa fa-whatsapp fa-fw me-2"/>
                                <a href="https://wa.me/6285733556953" target="_blank"
                                   rel="noopener">+62 857-3355-6953 (WhatsApp)</a>
                            </li>
                            <li><i class="fa fa-envelope fa-fw me-2"/>
                                <a href="mailto:hello@warunglakku.com">hello@warunglakku.com</a>
                            </li>
                            <li><i class="fa fa-globe fa-fw me-2"/>
                                <a href="/">warunglakku.com</a>
                            </li>
                            <li class="mt-3">
                                <strong>Jam Operasional:</strong><br/>
                                Senin – Minggu: 10:00 – 22:00 WIB
                            </li>
                        </ul>
                    </xpath>
                </data>
            </field>
        </record>
    </data>
</odoo>
