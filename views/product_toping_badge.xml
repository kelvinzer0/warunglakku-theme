<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Warung Lakku: "Toping" Badge
        ============================================================
        Shows a pill-shaped "Toping" badge on Seblak products priced
        below 6000 in BOTH the product list (shop grid) AND the
        product detail page.

        Rules for badge to appear:
          1. Product belongs to public category "Seblak" (id=6, parent_id=11)
          2. Product.list_price &lt; 6000

        Why "Toping" badge:
          - Seblak products with price &lt; 6000 are add-ons/toppings
            (kerupuk, bakso, sosis, dll) that customers add to their
            main Seblak bowl (which is priced &gt;= 6000).
          - Highlighting them as "Toping" helps customers quickly
            identify add-on items vs main dishes.

        Templates touched:
          - website_sale.products_item       (product card in /shop grid)
          - website_sale.shop_product_carousel (image carousel on detail page)

        Badge placement:
          - List: top-left corner of product image (position:absolute)
          - Detail: top-left corner of product carousel (position:absolute)

        Badge style (defined in static/src/scss/custom.scss):
          - Yellow gradient (WL brand color)
          - Maroon border + text
          - Pill shape with shadow
          - Mobile-responsive sizing

        Author: Kelvin Yuli Andrian
        Since:  v17.0.3.10.67
        Updated: v17.0.3.10.68 (threshold 5000 → 6000)
    -->

    <!-- === BADGE ON PRODUCT CARD (shop listing) === -->
    <template id="wl_toping_badge_list"
              name="WL: Toping badge on product card"
              inherit_id="website_sale.products_item"
              priority="99">
        <!--
            Inject badge inside the .oe_product_image container.
            We use position="inside" so the badge becomes a child
            of the image wrapper, then absolute-position it via CSS.
            The XPath matches the first div with class oe_product_image.
        -->
        <xpath expr="//div[hasclass('oe_product_image')]" position="inside">
            <t t-if="product.public_categ_ids and 6 in product.public_categ_ids.ids and product.list_price &lt; 6000">
                <div class="wl_toping_badge wl_toping_badge_list"
                     aria-label="Toping"
                     title="Produk toping untuk seblak">
                    <i class="fa fa-plus-circle"/> Toping
                </div>
            </t>
        </xpath>
    </template>

    <!-- === BADGE ON PRODUCT DETAIL PAGE === -->
    <template id="wl_toping_badge_detail"
              name="WL: Toping badge on product detail"
              inherit_id="website_sale.shop_product_carousel"
              priority="99">
        <!--
            Inject badge inside #o-carousel-product (the image carousel
            on the product detail page). Position:absolute via CSS
            places it at top-left of the image.

            NOTE: The carousel lives in template `website_sale.shop_product_carousel`,
            NOT `website_sale.product` (the parent which t-calls this child
            template). Trying to xpath #o-carousel-product from the parent
            view fails because it's rendered in the child view's scope.
        -->
        <xpath expr="//div[@id='o-carousel-product']" position="inside">
            <t t-if="product.public_categ_ids and 6 in product.public_categ_ids.ids and product.list_price &lt; 6000">
                <div class="wl_toping_badge wl_toping_badge_detail"
                     aria-label="Toping"
                     title="Produk toping untuk seblak">
                    <i class="fa fa-plus-circle"/> Toping
                </div>
            </t>
        </xpath>
    </template>

</odoo>
