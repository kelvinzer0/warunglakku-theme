<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Warung Lakku: Filter Chips / Pill Tabs / Tag Carousel on /shop
        ==============================================================
        Renders a horizontally-scrollable strip of pill-shaped category
        chips JUST ABOVE the products grid on /shop (i.e. BELOW the
        products_header toolbar). Each chip links to
        /shop?category=&lt;id&gt; (Odoo's native category filter URL).

        Data source: product.public.category records that are linked to
        at least one published product. These public categories mirror
        the WhatsApp Business collections synced by the n8n workflow
        (which writes to product.category under parent_id=7 "Warung
        Lakku"). The one-time sync script sync_public_categories.py
        bridges product.category to product.public.category.

        Active chip highlighting:
        - When URL is /shop (no filter): "Semua" chip is active.
        - When URL is /shop?category=&lt;id&gt;: matching chip is active.
        The `category` variable is set by Odoo's shop() controller in
        the template context.

        URL format:
        - "Semua" chip: href="/shop"
        - Category chips: href="/shop?category=&lt;id&gt;"  (integer id,
          NOT the recordset. Passing a recordset to keep() in Odoo 17
          produces a broken URL like "?category=product.public.category(1,)"
          that triggers HTTP 500.)

        Overflow-x scroll:
        - The .wl_filter_chips_scroll container is `display: flex` with
          `overflow-x: auto` so chips lay out horizontally and the row
          scrolls when overflowed.
        - Scroll snap (proximity) makes scrolling feel natural.
        - Scrollbar is styled to be subtle on desktop, hidden on mobile.
        - Each chip has `flex-shrink: 0` so they don't compress.

        NOTE on Odoo native filmstrip removal (v17.0.3.10.1):
        - Odoo's website_sale.products template renders a category
          navigation by calling the child template
          `website_sale.filmstrip_categories` via t-call. That child
          template renders the `o_wsale_filmstip_container` div (note:
          Odoo has a typo, it is "filmstip" not "filmstrip"). It shows
          as a row of Bootstrap-style buttons ABOVE the products grid.
        - We REMOVE that native filmstrip by replacing the t-call
          element in the parent view with an empty t. Our
          `wl_filter_chips` already serves the same purpose with a
          better mobile UX (overflow-x scroll, pill shape, count
          badge).
        - Without this removal, the /shop page would show TWO category
          strips: our chips at the top plus Odoo's filmstrip just above
          the grid. Duplicate UI that confused users.
    -->
    <record model="ir.ui.view" id="shop_filter_chips">
        <field name="name">Warung Lakku: Shop Filter Chips</field>
        <field name="key">theme_warunglakku.shop_filter_chips</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="website_sale.products"/>
        <field name="priority">98</field>
        <field name="arch" type="xml">
            <data>
                <!--
                    1) REMOVE Odoo's native category filmstrip to avoid
                       duplicate UI. We replace the t-call element that
                       invokes website_sale.filmstrip_categories with an
                       empty t, so the filmstrip never renders. (We
                       cannot xpath the o_wsale_filmstip_container div
                       directly because it lives in the called child
                       template, not in this parent view.)
                -->
                <xpath expr="//t[@t-call='website_sale.filmstrip_categories']" position="replace">
                    <t/>
                </xpath>

                <!--
                    2) INJECT our pill-shaped filter chips JUST ABOVE the
                       products grid table wrapper (i.e. below the
                       products_header toolbar). This is the same
                       position where Odoo's native filmstrip used to
                       live, so the visual order on /shop becomes:

                         [search/sort toolbar]
                         [our pill chips, here]
                         [products grid]

                       instead of the previous (pre-v3.10.1) layout:

                         [our pill chips, duplicate top]
                         [search/sort toolbar]
                         [Odoo native filmstrip, duplicate bottom]
                         [products grid]
                -->
                <xpath expr="//div[contains(@class, 'o_wsale_products_grid_table_wrapper')]" position="before">
                    <t t-set="wl_chip_cats" t-value="website.get_warunglakku_shop_chips()"/>
                    <t t-if="wl_chip_cats">
                        <nav class="wl_filter_chips_container" role="tablist" aria-label="Filter kategori produk">
                            <div class="wl_filter_chips_scroll">
                                <a t-att-href="'/shop'"
                                   t-att-class="'wl_chip' + ('' if category else ' wl_chip_active')"
                                   role="tab"
                                   t-att-aria-selected="'true' if not category else 'false'">
                                    <i class="fa fa-th-large"/>
                                    <span>Semua</span>
                                </a>
                                <t t-foreach="wl_chip_cats" t-as="chip">
                                    <a t-att-href="'/shop?category=%d' % chip['id']"
                                       t-att-class="'wl_chip' + (' wl_chip_active' if category and category.id == chip['id'] else '')"
                                       role="tab"
                                       t-att-aria-selected="'true' if category and category.id == chip['id'] else 'false'">
                                        <span t-esc="chip['name']"/>
                                        <span class="wl_chip_count" t-esc="chip['published_count']"/>
                                    </a>
                                </t>
                            </div>
                        </nav>
                    </t>
                    <!-- Inline JS for operating hours live status.
                         Injected here (inside the position="before"
                         xpath) to avoid breaking the t-if/t-else
                         chain on the parent products_grid view. -->
                    <t t-call="theme_warunglakku.warunglakku_operating_hours_inline_js"/>
                </xpath>
            </data>
        </field>
    </record>

</odoo>
