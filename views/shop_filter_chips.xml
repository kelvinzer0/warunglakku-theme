<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Warung Lakku: Filter Chips / Pill Tabs / Tag Carousel on /shop
        ==============================================================
        Renders a horizontally-scrollable strip of pill-shaped category
        chips above the products grid on /shop. Each chip links to
        /shop/category/<slug>-<id> (Odoo's native category filter URL,
        generated by the `keep()` helper).

        Data source: product.public.category records that are linked to
        at least one published product. These public categories mirror
        the WhatsApp Business collections synced by the n8n workflow
        (which writes to product.category under parent_id=7 "Warung
        Lakku"). The one-time sync script sync_public_categories.py
        bridges product.category → product.public.category.

        Active chip highlighting:
        - When URL is /shop (no filter): "Semua" chip is active.
        - When URL is /shop?category=<id>: matching chip is active.
          (Odoo parses the int id from the query string and binds it to
          a product.public.category recordset in the template context.)
        The `category` variable is set by Odoo's shop() controller in
        the template context.

        URL format:
        - "Semua" chip: href="/shop"
        - Category chips: href="/shop?category=<id>"  (integer id, NOT
          the recordset — passing a recordset to keep() in Odoo 17
          produces a broken URL like "?category=product.public.category(1,)"
          that triggers HTTP 500.)

        Overflow-x scroll:
        - The .wl_filter_chips_scroll container is `display: flex` with
          `overflow-x: auto` so chips lay out horizontally and the row
          scrolls when overflowed.
        - Scroll snap (proximity) makes scrolling feel natural.
        - Scrollbar is styled to be subtle on desktop, hidden on mobile.
        - Each chip has `flex-shrink: 0` so they don't compress.
    -->
    <record model="ir.ui.view" id="shop_filter_chips">
        <field name="name">Warung Lakku: Shop Filter Chips</field>
        <field name="key">theme_warunglakku.shop_filter_chips</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="website_sale.products"/>
        <field name="priority">98</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//div[@id='products_grid']/div[contains(@class, 'products_header')]" position="before">
                    <t t-set="wl_chip_cats" t-value="website.get_warunglakku_shop_chips()"/>
                    <t t-if="wl_chip_cats">
                        <nav class="wl_filter_chips_container" role="tablist" aria-label="Filter kategori produk">
                            <div class="wl_filter_chips_scroll">
                                <a t-att-href="'/shop'"
                                   t-att-class="'wl_chip' + ('' if category else ' wl_chip_active')"
                                   role="tab"
                                   t-att-aria-selected="'true' if not category else 'false'">
                                    <i class="fa fa-th-large"/>
                                    <span>Semua</span>
                                </a>
                                <t t-foreach="wl_chip_cats" t-as="chip">
                                    <a t-att-href="'/shop?category=%d' % chip.id"
                                       t-att-class="'wl_chip' + (' wl_chip_active' if category and category.id == chip.id else '')"
                                       role="tab"
                                       t-att-aria-selected="'true' if category and category.id == chip.id else 'false'">
                                        <span t-field="chip.name"/>
                                        <t t-if="chip.product_tmpl_ids">
                                            <span class="wl_chip_count" t-esc="len(chip.product_tmpl_ids)"/>
                                        </t>
                                    </a>
                                </t>
                            </div>
                        </nav>
                    </t>
                </xpath>
            </data>
        </field>
    </record>

</odoo>
