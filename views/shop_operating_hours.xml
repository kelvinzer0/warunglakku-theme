<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Warung Lakku: Shop Sidebar Operating Hours Widget
        =================================================
        The default `#products_grid_before` aside on /shop is empty
        when no product attributes/categories are configured. Fill
        it with an operating-hours card synced from Evolution API
        (cached 24h in ir.config_parameter by the
        website_sale_pickup_at_store module).

        Data is computed server-side via website.get_warunglakku_operating_hours()
        (see models/website_operating_hours.py) so the card renders
        fully on first paint, no AJAX needed.

        Client-side re-evaluation (v17.0.3.10.2):
        - Odoo caches the /shop HTML server-side. At 20:00 sharp,
          if a cached page from 19:59 is served, the widget would
          still show "Buka Sekarang" even though the store is now
          closed. To fix this, we embed the today's open/close
          times as data-* attributes on the .wl_oh_status element.
          A small JS in theme.js re-evaluates the status every
          30 seconds on the client and corrects it if the server
          render is stale.
        - Also adds a "closing soon" (Akan Tutup) intermediate
          state shown for the last 30 minutes before close_time,
          so customers get a clear visual warning.
    -->
    <record model="ir.ui.view" id="shop_operating_hours_sidebar">
        <field name="name">Warung Lakku: Shop Sidebar Operating Hours</field>
        <field name="key">theme_warunglakku.shop_operating_hours_sidebar</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="website_sale.products"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//div[contains(@class, 'o_wsale_products_grid_before_rail')]/div[contains(@class, 'products_attributes_filters')]" position="before">
                    <t t-set="oh" t-value="website.get_warunglakku_operating_hours()"/>
                    <t t-set="oh_today" t-value="oh.get('today') or {}"/>
                    <div class="wl_oh_card"
                         t-att-data-available="'true' if oh.get('available') else 'false'"
                         t-att-data-today-mode="oh_today.get('mode') or 'closed'"
                         t-att-data-today-open="oh_today.get('open_time') or ''"
                         t-att-data-today-close="oh_today.get('close_time') or ''">
                        <div class="wl_oh_header">
                            <i class="fa fa-clock-o"/>
                            <span>Jam Operasional</span>
                        </div>
                        <t t-if="oh.get('available')">
                            <div class="wl_oh_status"
                                 t-att-data-open="'true' if oh.get('is_open_now') else 'false'"
                                 t-att-data-state="'open' if oh.get('is_open_now') else 'closed'">
                                <span class="wl_oh_dot"/>
                                <t t-if="oh.get('is_open_now')">
                                    <span class="wl_oh_status_text">Buka Sekarang</span>
                                </t>
                                <t t-else="">
                                    <span class="wl_oh_status_text">Tutup</span>
                                </t>
                            </div>
                            <ul class="wl_oh_days">
                                <t t-foreach="oh.get('days', [])" t-as="day">
                                    <li t-att-class="'wl_oh_day' + (' wl_oh_day_today' if day.get('is_today') else '') + (' wl_oh_day_open' if day.get('is_open') else '')">
                                        <span class="wl_oh_day_name">
                                            <t t-esc="day.get('name')"/>
                                            <t t-if="day.get('is_today')">
                                                <span class="wl_oh_today_badge">Hari ini</span>
                                            </t>
                                        </span>
                                        <span class="wl_oh_day_hours" t-esc="day.get('hours_display')"/>
                                    </li>
                                </t>
                            </ul>
                            <div class="wl_oh_footer">
                                <div class="wl_oh_sync">
                                    <i class="fa fa-whatsapp"/>
                                    <small>Disinkronkan dari WhatsApp Business</small>
                                </div>
                                <t t-if="oh.get('fetched_at')">
                                    <small class="wl_oh_updated">
                                        Diperbarui: <t t-esc="oh.get('fetched_at')"/>
                                    </small>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="wl_oh_empty">
                                <i class="fa fa-info-circle"/>
                                <span>Jam operasional belum tersedia.</span>
                            </div>
                        </t>
                    </div>
                </xpath>
            </data>
        </field>
    </record>

    <!--
        Inline JS for operating hours live status (v17.0.3.10.2)
        =====================================================
        We bypass Odoo's asset bundle system entirely and inline a
        small self-executing script via the filter chips template
        (which is already injected at position="before" on the
        products grid wrapper, so it doesn't break the t-if/t-else
        chain on the parent view).

        The script does two things:
        1) Re-evaluates the open/closed status every 30 seconds on
           the client. This bypasses Odoo's server-side HTML cache,
           which could otherwise serve a stale "Buka Sekarang" badge
           at 20:00 sharp if the cached page was rendered at 19:59.
        2) Adds an intermediate "Akan Tutup" (Closing Soon) state
           shown for the last 30 minutes before close_time.
    -->
    <template id="warunglakku_operating_hours_inline_js" name="Warung Lakku: OH Live JS">
        <script>
<![CDATA[
            (function () {
                'use strict';
                var JAKARTA_OFFSET_MIN = 7 * 60;

                function nowMinutesInJakarta() {
                    var now = new Date();
                    var utcMin = now.getUTCHours() * 60 + now.getUTCMinutes();
                    var jakartaMin = utcMin + JAKARTA_OFFSET_MIN;
                    return ((jakartaMin % 1440) + 1440) % 1440;
                }

                function computeState(mode, openStr, closeStr) {
                    if (mode === 'open_24_hours') return 'open';
                    if (mode === 'specific_hours') {
                        var openMin = parseInt(openStr, 10);
                        var closeMin = parseInt(closeStr, 10);
                        if (isNaN(openMin) || isNaN(closeMin)) return 'closed';
                        var now = nowMinutesInJakarta();
                        if (now < openMin || now >= closeMin) return 'closed';
                        if (closeMin - now <= 30) return 'closing_soon';
                        return 'open';
                    }
                    return 'closed';
                }

                var STATE_TEXT = {
                    'open': 'Buka Sekarang',
                    'closing_soon': 'Akan Tutup',
                    'closed': 'Tutup'
                };

                function updateWidget(widgetEl) {
                    if (!widgetEl) return;
                    var mode = widgetEl.getAttribute('data-today-mode') || 'closed';
                    var openStr = widgetEl.getAttribute('data-today-open') || '';
                    var closeStr = widgetEl.getAttribute('data-today-close') || '';
                    var state = computeState(mode, openStr, closeStr);
                    var statusEls = widgetEl.querySelectorAll('.wl_oh_status, .wl_oh_mobile_status');
                    for (var i = 0; i < statusEls.length; i++) {
                        var statusEl = statusEls[i];
                        if (statusEl.getAttribute('data-state') === state) continue;
                        statusEl.setAttribute('data-state', state);
                        statusEl.setAttribute('data-open', state === 'open' ? 'true' : 'false');
                        var textEl = statusEl.querySelector('.wl_oh_status_text');
                        if (textEl) textEl.textContent = STATE_TEXT[state] || 'Tutup';
                    }
                    if (widgetEl.classList.contains('wl_oh_mobile')) {
                        widgetEl.setAttribute('data-open', state === 'open' ? 'true' : 'false');
                    }
                }

                function updateAll() {
                    var widgets = document.querySelectorAll('.wl_oh_card, .wl_oh_mobile');
                    for (var i = 0; i < widgets.length; i++) updateWidget(widgets[i]);
                }

                function init() {
                    setTimeout(updateAll, 200);
                    setInterval(updateAll, 30000);
                    document.addEventListener('visibilitychange', function () {
                        if (!document.hidden) updateAll();
                    });
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }
            })();
]]>
        </script>
    </template>

    <!--
        Mobile-only operating hours accordion
        =====================================
        The sidebar aside (#products_grid_before) is `d-none d-lg-block`
        so it never renders on mobile. Inject a compact <details>
        accordion right above the products toolbar, visible only on
        screens below lg (992px). Default collapsed = just status
        + today's hours; tap to expand = full 7-day list.
    -->
    <record model="ir.ui.view" id="shop_operating_hours_mobile">
        <field name="name">Warung Lakku: Shop Mobile Operating Hours</field>
        <field name="key">theme_warunglakku.shop_operating_hours_mobile</field>
        <field name="type">qweb</field>
        <field name="inherit_id" ref="website_sale.products"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//div[@id='products_grid']/div[contains(@class, 'products_header')]" position="before">
                    <t t-set="oh_m" t-value="website.get_warunglakku_operating_hours()"/>
                    <t t-set="oh_m_today" t-value="oh_m.get('today') or {}"/>
                    <details class="wl_oh_mobile d-lg-none"
                             t-att-data-available="'true' if oh_m.get('available') else 'false'"
                             t-att-data-open="'true' if oh_m.get('is_open_now') else 'false'"
                             t-att-data-today-mode="oh_m_today.get('mode') or 'closed'"
                             t-att-data-today-open="oh_m_today.get('open_time') or ''"
                             t-att-data-today-close="oh_m_today.get('close_time') or ''">
                        <summary class="wl_oh_mobile_summary">
                            <span class="wl_oh_mobile_left">
                                <i class="fa fa-clock-o"/>
                                <span class="wl_oh_mobile_title">Jam Operasional</span>
                            </span>
                            <t t-if="oh_m.get('available')">
                                <span class="wl_oh_mobile_status"
                                      t-att-data-open="'true' if oh_m.get('is_open_now') else 'false'"
                                      t-att-data-state="'open' if oh_m.get('is_open_now') else 'closed'">
                                    <span class="wl_oh_dot"/>
                                    <t t-if="oh_m.get('is_open_now')">
                                        <span class="wl_oh_status_text">Buka Sekarang</span>
                                    </t>
                                    <t t-else="">
                                        <span class="wl_oh_status_text">Tutup</span>
                                    </t>
                                </span>
                                <t t-set="today_m" t-value="oh_m.get('today')"/>
                                <t t-if="today_m">
                                    <span class="wl_oh_mobile_today">
                                        <t t-esc="today_m.get('name')"/>: <t t-esc="today_m.get('hours_display')"/>
                                    </span>
                                </t>
                                <i class="fa fa-angle-down wl_oh_mobile_chevron"/>
                            </t>
                            <t t-else="">
                                <span class="wl_oh_mobile_unavailable">Belum tersedia</span>
                            </t>
                        </summary>
                        <t t-if="oh_m.get('available')">
                            <div class="wl_oh_mobile_body">
                                <ul class="wl_oh_days">
                                    <t t-foreach="oh_m.get('days', [])" t-as="day">
                                        <li t-att-class="'wl_oh_day' + (' wl_oh_day_today' if day.get('is_today') else '') + (' wl_oh_day_open' if day.get('is_open') else '')">
                                            <span class="wl_oh_day_name">
                                                <t t-esc="day.get('name')"/>
                                                <t t-if="day.get('is_today')">
                                                    <span class="wl_oh_today_badge">Hari ini</span>
                                                </t>
                                            </span>
                                            <span class="wl_oh_day_hours" t-esc="day.get('hours_display')"/>
                                        </li>
                                    </t>
                                </ul>
                                <div class="wl_oh_footer">
                                    <div class="wl_oh_sync">
                                        <i class="fa fa-whatsapp"/>
                                        <small>Disinkronkan dari WhatsApp Business</small>
                                    </div>
                                    <t t-if="oh_m.get('fetched_at')">
                                        <small class="wl_oh_updated">
                                            Diperbarui: <t t-esc="oh_m.get('fetched_at')"/>
                                        </small>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </details>
                </xpath>
            </data>
        </field>
    </record>

</odoo>
